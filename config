# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.
default_orientation auto
### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
set $term tilix
# Your preferred application launcher
set $menu wmenu-run
input type:keyboard {
    xkb_layout "us,latam"
}
include /etc/sway/config-vars.d/*

# configuracion personal bajo archivos .conf
include /etc/sway/config.d/*
include ~/.config/sway/70-theme.conf
include ~/.config/sway/10-input.conf
include ~/.config/sway/20-output.conf
include ~/.config/sway/30-keybindings.conf
include ~/.config/sway/90-autostart.conf
